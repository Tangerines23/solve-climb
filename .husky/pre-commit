#!/bin/sh

set -e

echo "🔍 검증 시작..."

# 0. 의존성 무결성 체크 (신규: 로컬 환경 누락 방지)
echo "📦 의존성 무결성 체크..."
if ! node scripts/check-dependency-integrity.js; then
  exit 1
fi

# 1. TypeScript 타입 체크 (필수 - 전체 프로젝트)
echo "1️⃣ TypeScript 타입 체크..."
if ! npm run type-check 2>&1; then
  echo ""
  echo "❌ TypeScript 타입 체크 실패"
  echo "💡 타입 에러를 수정한 후 다시 커밋해주세요"
  exit 1
fi

# 1.5. 미사용 코드/파일 검사 (Knip) - 다이어트
echo "1️⃣.5️⃣ 미사용 코드/파일 검사 (Knip)..."
if ! npm run diet; then
    echo "❌ 미사용 코드나 의존성이 발견되었습니다!"
    echo "💡 'npm run diet' 결과를 확인하고 정리해주세요."
    exit 1
fi

# 2. lint-staged 실행 (변경된 파일만 ESLint + Prettier)
echo "2️⃣ lint-staged 실행 (변경된 파일만 검사 및 자동 수정)..."
if ! npx lint-staged 2>&1; then
  echo ""
  echo "❌ lint-staged 검증 실패"
  echo "💡 ESLint 또는 Prettier 에러가 있습니다"
  echo "💡 자동 수정된 파일이 있으면 다시 커밋해주세요"
  exit 1
fi

# 3. 미사용 자산(Assets) 검사 (Public 폴더)
echo "3️⃣ 미사용 자산(Assets) 검사..."
if ! npm run check:assets; then
    echo "🚫 사용되지 않는 자산이 발견되었습니다! (scripts/find-unused-assets.js 확인)"
    exit 1
fi

# 4. 네비게이션 및 코드 무결성 검증 (종합)
echo "4️⃣ 코드 무결성 검증 (오타, 매직스트링, CSS, 네비게이션)..."
if ! npm run check:integrity; then
    echo "🚫 코드 무결성 검사 실패! (npm run check:integrity 를 확인하세요)"
    exit 1
fi

# 6. 보안 및 성능 검사 (경고 위주)
echo "6️⃣ 보안 및 성능 검사..."
if ! npm run check:secrets; then
    echo "🚫 보안 키(Secrets)가 코드에 포함되어 있습니다!"
    exit 1
fi

if ! npm run check:circular; then
    echo "🚫 순환 참조가 발견되었습니다!"
    exit 1
fi

# 로직 성능 및 보안 감사는 경고로 처리 (상세 검증은 CI에서 수행)
npm run check:logic || echo "⚠️ 로직 성능 저하 감지됨 (CI에서 재확인 예정)"
if npm run check:security; then
  echo "✅ 보안 검사 완료"
else
  echo "⚠️ 보안 취약점 발견 (자동 수정을 시도했습니다)"
  # package-lock.json이 수정되었다면 다시 스테이지에 추가
  if [ -n "$(git status --porcelain package-lock.json)" ]; then
    echo "♻️ 자동 수정된 package-lock.json을 스테이지에 추가합니다..."
    git add package-lock.json
  fi
fi

# Socket 의존성 보안 스캔 (토큰 하나 돌려쓰기: SOCKET_API_KEY 권장, CLI용 이름도 지원)
if [ -n "$SOCKET_API_KEY" ] || [ -n "$SOCKET_CLI_API_TOKEN" ] || [ -n "$SOCKET_SECURITY_API_TOKEN" ]; then
  echo "🔒 Socket 의존성 보안 스캔..."
  [ -n "$SOCKET_API_KEY" ] && export SOCKET_CLI_API_TOKEN="$SOCKET_API_KEY"
  npm run check:socket || echo "⚠️ Socket 스캔 이슈 (socket.dev 정책 확인 권장)"
else
  echo "⏭️ Socket 스캔 건너뜀 (SOCKET_API_KEY 등 미설정)"
fi

# Supabase 연결 확인 (실패해도 커밋 진행 — 네트워크/429 등 외부 요인 때문)
echo "🔗 Supabase 연결 확인 (.env 키 유효성)..."
npm run check:supabase:connection || echo "⚠️ Supabase 연결 실패 — 오프라인이거나 .env 키 확인 필요"

# 6. 용량 검사 (번들 사이즈 체크)
# 6. 용량 검사 (번들 사이즈 체크) - CI로 이관됨
# echo "6️⃣ 용량 검사 (Bundle Size)..."
# if ! npm run check:size 2>&1; then
#   echo ""
#   echo "⚠️  용량 제한 초과"
#   echo "💡 'npm run analyze'를 실행하여 원인을 분석해보세요."
#   # exit 1  # 빡빡하게 막으려면 주석 해제
# fi

# 6. E2E 및 가혹 환경 테스트 (선택적 - 속도를 위해 CI권장)
# echo "6️⃣ 가혹 환경 테스트 (Stress/Chaos)..."
# if ! npm run test:stress; then
#   echo "❌ 가혹 환경 테스트 실패! 느린 네트워크 환경에서 대응이 부족합니다."
#   exit 1
# fi

# 7. 레이아웃 검증 (서버 없으면 자동 기동 후 검사. 이미 서버 떠 있으면 그대로 사용)
echo "7️⃣ 레이아웃 검증 (Basic Layout Check)..."
if ! npm run check:layout:with-server; then
    echo "🚫 레이아웃 깨짐 발견! (npm run check:layout:with-server 확인)"
    exit 1
fi

# 8. DB 검증 (조건부)
DB_CHANGED=$(node scripts/check-db-changes.js 2>/dev/null || echo "")
if [ -n "$DB_CHANGED" ]; then
  echo "7️⃣ DB 검증..."
  echo "$DB_CHANGED - DB 검증 실행..."
  if ! npm run check:db 2>&1; then
    echo ""
    echo "❌ DB 검증 실패"
    echo "💡 DB 마이그레이션 또는 스키마에 문제가 있습니다"
    exit 1
  fi
fi

# 9. 작업 완료 및 환경 정리 (로그 수집 장치 가동)
echo "🧹 환경 정리 (배정되지 않은 로그 및 보고서 분류)..."
npm run report:collect || echo "⚠️ 로그 수집 중 경고 발생 (수동 확인 권장)"

# 자동 수정된 파일이 있을 경우 다시 스테이지에 추가 (최종 확인)
# 소스 코드 외에 자동 생성되거나 수정된 파일들을 안전하게 포함시킵니다.
if [ -n "$(git status --porcelain | grep -E 'package-lock.json|src/.*\.tsx?|src/.*\.css')" ]; then
  echo "♻️ 누락된 자동 수정 사항을 스테이지에 추가합니다..."
  git status --porcelain | grep -E 'package-lock.json|src/.*\.tsx?|src/.*\.css' | awk '{print $2}' | xargs git add
fi

echo ""
echo "✅ 모든 검증 통과!"
echo "🎉 워크스페이스가 정리되었습니다."
