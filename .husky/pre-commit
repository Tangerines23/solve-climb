#!/bin/sh

set -e

echo "🔍 검증 시작..."

# 1. TypeScript 타입 체크 (필수)
echo "1️⃣ TypeScript 타입 체크..."
npm run type-check || {
  echo "❌ TypeScript 타입 체크 실패"
  exit 1
}

# 2. ESLint 검증 (필수)
echo "2️⃣ ESLint 검증..."
npm run lint || {
  echo "❌ ESLint 검증 실패"
  exit 1
}

# 3. Prettier 포맷팅 체크 (필수)
echo "3️⃣ Prettier 포맷팅 체크..."
npm run format:check || {
  echo "❌ Prettier 포맷팅 실패"
  echo "💡 'npm run format' 실행 후 다시 커밋해주세요"
  exit 1
}

# 4. 보안 검사 (경고만 - 느려서 실패해도 커밋 가능)
echo "4️⃣ 보안 검사 (의존성 취약점)..."
npm run check:security 2>/dev/null || {
  echo "⚠️  보안 취약점 발견"
  echo "💡 'npm audit' 실행하여 상세 확인 권장"
  echo "💡 계속하려면 'git commit --no-verify' 사용 가능 (권장하지 않음)"
  # exit 1  # 엄격하게 하려면 주석 해제
}

# 5. 테스트 실행 (선택적 - 경고만)
echo "5️⃣ 테스트 실행..."
npm run test -- --run || {
  echo "⚠️  테스트 실패"
  echo "💡 CI에서 재확인 예정"
  # exit 1  # 엄격하게 하려면 주석 해제
}

# 6. DB 검증 (조건부)
DB_CHANGED=$(node scripts/check-db-changes.js 2>/dev/null || echo "")
if [ -n "$DB_CHANGED" ]; then
  echo "6️⃣ DB 검증..."
  echo "$DB_CHANGED - DB 검증 실행..."
  npm run check:db || {
    echo "❌ DB 검증 실패"
    exit 1
  }
fi

echo ""
echo "✅ 모든 검증 통과!"
