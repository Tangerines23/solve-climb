#!/bin/sh

set -e

echo "🔍 검증 시작..."

# 1. TypeScript 타입 체크 (필수 - 전체 프로젝트)
echo "1️⃣ TypeScript 타입 체크..."
if ! npm run type-check 2>&1; then
  echo ""
  echo "❌ TypeScript 타입 체크 실패"
  echo "💡 타입 에러를 수정한 후 다시 커밋해주세요"
  exit 1
fi

# 2. lint-staged 실행 (변경된 파일만 ESLint + Prettier)
echo "2️⃣ lint-staged 실행 (변경된 파일만 검사 및 자동 수정)..."
if ! npx lint-staged 2>&1; then
  echo ""
  echo "❌ lint-staged 검증 실패"
  echo "💡 ESLint 또는 Prettier 에러가 있습니다"
  echo "💡 자동 수정된 파일이 있으면 다시 커밋해주세요"
  exit 1
fi

# 3. CSS 검증 (조건부 - CSS 파일 변경 시에만)
CSS_CHANGED=$(node scripts/check-css-changes.js 2>/dev/null || echo "")
if [ -n "$CSS_CHANGED" ]; then
  echo "3️⃣ CSS 검증..."
  echo "$CSS_CHANGED - CSS 검증 실행..."
  if ! npm run check:css 2>&1; then
    echo ""
    echo "❌ CSS 검증 실패"
    echo "💡 하드코딩된 CSS 값이 발견되었습니다"
    echo "💡 CSS 변수를 사용하도록 수정해주세요 (docs/DESIGN_SYSTEM.md 참고)"
    exit 1
  fi
fi

# 4. 네비게이션 검증 (조건부 - TS/TSX 파일 변경 시에만)
NAV_CHANGED=$(node scripts/check-nav-changes.js 2>/dev/null || echo "")
if [ -n "$NAV_CHANGED" ]; then
  echo "4️⃣ 네비게이션 검증 (UrlBuilder 사용 여부)..."
  if ! npm run check:nav 2>&1; then
    echo ""
    echo "❌ 네비게이션 검증 실패"
    echo "💡 직접적인 navigate('주소') 호출이 발견되었습니다"
    echo "💡 src/utils/navigation.ts의 urls 객체를 사용해주세요"
    exit 1
  fi
fi

# 5. 보안 검사 (경고만 - 느려서 실패해도 커밋 가능)
echo "5️⃣ 보안 검사 (의존성 취약점)..."
npm run check:security 2>/dev/null || {
  echo "⚠️  보안 취약점 발견"
  echo "💡 'npm audit' 실행하여 상세 확인 권장"
  echo "💡 계속하려면 'git commit --no-verify' 사용 가능 (권장하지 않음)"
  # exit 1  # 엄격하게 하려면 주석 해제
}

# 6. 테스트 실행 (선택적 - 경고만)
echo "6️⃣ 테스트 실행..."
npm run test -- --run || {
  echo "⚠️  테스트 실패"
  echo "💡 CI에서 재확인 예정"
  # exit 1  # 엄격하게 하려면 주석 해제
}

# 7. DB 검증 (조건부)
DB_CHANGED=$(node scripts/check-db-changes.js 2>/dev/null || echo "")
if [ -n "$DB_CHANGED" ]; then
  echo "7️⃣ DB 검증..."
  echo "$DB_CHANGED - DB 검증 실행..."
  if ! npm run check:db 2>&1; then
    echo ""
    echo "❌ DB 검증 실패"
    echo "💡 DB 마이그레이션 또는 스키마에 문제가 있습니다"
    exit 1
  fi
fi

echo ""
echo "✅ 모든 검증 통과!"
