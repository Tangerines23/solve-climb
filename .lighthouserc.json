{
  "ci": {
    "collect": {
      "startServerCommand": "npm run dev",
      "url": ["http://localhost:5173/", "http://localhost:5173/ranking"],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.8
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.9
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
