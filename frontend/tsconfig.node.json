{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "allowJs": true
  },
  "include": [
    "vite.config.ts",
    "granite.config.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "eslint.config.js"
  ]
}
