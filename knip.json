{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "vitest": false,
  "entry": ["src/main.tsx", "src/utils/tossAuth.ts"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/vite-env.d.ts",
    "vitest.workspace.js",
    "src/types/**",
    "src/utils/navigation.ts",
    "src/utils/tossGameLogin.ts",
    "src/utils/MathProblemGenerator.ts"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "exports": "off",
    "types": "off",
    "files": "warn"
  }
}
