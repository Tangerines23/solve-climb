{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "vitest": false,
    "entry": [
        "src/main.tsx",
        "src/utils/tossAuth.ts"
    ],
    "project": [
        "src/**/*.{ts,tsx}"
    ],
    "ignore": [
        "src/vite-env.d.ts",
        "vitest.workspace.js"
    ],
    "ignoreDependencies": [
