{
  "name": "react-vite-app",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "granite dev",
    "build": "vite build && node scripts/create-granite-config.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint && npm run format:check && npm run check:css && npm run check:nav",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run check:css && npm run check:nav",
    "validate:quick": "npm run lint -- --max-warnings=0",
    "validate:full": "npm run validate && npm run test && npm run check:db",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest --project=unit",
    "test:integration": "vitest --project=integration --run",
    "test:all": "vitest --run",
    "test:coverage": "vitest --coverage --run --coverage.reporter=text --coverage.reporter=json-summary --coverage.reporter=lcov --coverage.reporter=html",
    "test:coverage:unit": "vitest --project=unit --coverage --run",
    "test:components": "vitest src/components src/pages --run",
    "test:utils": "vitest src/utils src/stores --run",
    "test:coverage:components": "vitest src/components src/pages --coverage --run",
    "test:coverage:utils": "vitest src/utils src/stores --coverage --run",
    "test:bench": "vitest bench --run",
    "analyze": "cross-env ANALYZE=true vite build",
    "preview": "vite preview",
    "deploy": "ait deploy",
    "test:e2e": "playwright test",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:ct:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:visual": "playwright test --grep Visual",
    "test:visual:update": "playwright test --grep Visual --update-snapshots",
    "check:css": "node scripts/check-hardcoded-values.js",
    "check:basic-auth": "node scripts/check-basic-auth.js",
    "check:migrations": "node scripts/check-migrations.js",
    "check:db:migrations": "npx supabase migration list",
    "check:db:lint": "npx supabase db lint --linked --fail-on error",
    "check:db:diff": "npx supabase db diff --linked",
    "check:db:full": "npm run check:migrations && npm run check:db:migrations && npm run check:db:lint && npm run check:db:diff",
    "check:db": "npm run check:migrations && npm run check:db:migrations && npm run check:db:lint",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "check:nav": "node scripts/check-navigation.cjs",
    "check:size": "node scripts/check-bundle-size.js",
    "check:security": "npm audit --audit-level=moderate",
    "prepare": "husky"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^1.7.0",
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@emotion/react": "^11.14.0",
    "@supabase/supabase-js": "^2.84.0",
    "framer-motion": "^12.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@capacitor/cli": "^8.0.1",
    "@eslint/js": "^9.36.0",
    "@playwright/experimental-ct-react": "^1.57.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.9",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-istanbul": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "cross-env": "^10.1.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "glob": "^13.0.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.7",
    "prettier": "^3.7.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "supabase": "^2.72.8",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "find-my-way": "^8.2.2",
    "ip": "npm:ipaddr.js@^2.1.0",
    "@react-native-community/cli-doctor": {
      "ip": "npm:ipaddr.js@^2.1.0"
    },
    "@react-native-community/cli-hermes": {
      "ip": "npm:ipaddr.js@^2.1.0"
    },
    "tar": "7.5.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,css}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
