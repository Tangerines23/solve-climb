{
  "name": "react-vite-app",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "granite dev",
    "build": "vite build && node scripts/create-granite-config.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint && npm run format:check && npm run check:css",
    "preview": "vite preview",
    "deploy": "ait deploy",
    "check:css": "node scripts/check-hardcoded-values.js",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "check:security": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^1.4.7",
    "@emotion/react": "^11.14.0",
    "@supabase/supabase-js": "^2.84.0",
    "@toss/tds-colors": "^0.1.0",
    "@toss/tds-mobile": "^2.1.2",
    "@toss/tds-mobile-ait": "^2.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "prettier": "^3.7.4",
    "supabase": "^2.67.1",
    "vite": "^7.1.7"
  }
}
