{
  "name": "react-vite-app",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup-new-env.js",
    "dev": "vite --host",
    "generate": "plop",
    "diet": "knip",
    "images:optimize": "node scripts/optimize-images.js",
    "build": "npm run images:optimize && vite build && node scripts/create-granite-config.js",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint && npm run format:check && npm run check:css && npm run check:nav",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run check:css && npm run check:nav && npm run check:secrets && npm run check:circular && npm run check:integrity && npm run check:logic",
    "validate:fast": "npm run type-check && npm run lint",
    "validate:quick": "npm run lint -- --max-warnings=0",
    "validate:full": "npm run validate && npm run test && npm run check:db",
    "ci:local": "npm run type-check && npm run lint && npm run format:check && npm run check:secrets && npm run check:circular && npm run check:integrity && npm run check:logic && npm run test:bench && npm run test:all && npm run check:security && npm run build && npm run test:e2e:critical",
    "ci:local:stage1": "npm run type-check && npm run lint && npm run format:check && npm run check:secrets && npm run check:circular && npm run check:integrity && npm run check:logic && npm run check:migrations && npm run test:bench && npm run test:all && npm run check:security",
    "ci:local:full": "bash scripts/ci-local-full.sh",
    "ci:local:all": "bash scripts/ci-local-all.sh",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest --project=unit",
    "test:integration": "vitest --project=integration --run",
    "test:all": "vitest --run",
    "test:coverage": "vitest --coverage --run --coverage.reporter=text --coverage.reporter=json-summary --coverage.reporter=lcov --coverage.reporter=html",
    "test:coverage:unit": "vitest --project=unit --coverage --run",
    "test:components": "vitest src/components src/pages --run",
    "test:utils": "vitest src/utils src/stores --run",
    "test:coverage:components": "vitest src/components src/pages --coverage --run",
    "test:coverage:utils": "vitest src/utils src/stores --coverage --run",
    "test:rpc": "vitest tests/integration/rpc-validation.test.ts --run",
    "test:bench": "vitest bench --run",
    "analyze": "cross-env ANALYZE=true vite build",
    "preview": "vite preview",
    "deploy": "ait deploy",
    "test:e2e": "node scripts/run-playwright-with-port.js",
    "test:e2e:critical": "node scripts/run-playwright-with-port.js tests/e2e/smoke.spec.ts tests/e2e/core-business-scenario.spec.ts tests/e2e/verify.spec.ts tests/e2e/network-diagnostic.spec.ts",
    "test:e2e:auth-db": "node scripts/run-playwright-with-port.js tests/e2e/auth-test.spec.ts tests/e2e/db-status-check.spec.ts",
    "test:e2e:verify": "node scripts/verify-e2e-with-result.js critical",
    "test:e2e:visual": "node scripts/run-playwright-with-port.js --grep Visual tests/e2e/visual-regression.spec.ts",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:ct:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:visual": "node scripts/run-playwright-with-port.js --grep Visual",
    "test:visual:update": "node scripts/run-playwright-with-port.js --grep Visual --update-snapshots",
    "test:a11y": "node scripts/run-playwright-with-port.js tests/e2e/accessibility.spec.ts",
    "test:a11y:headed": "node scripts/run-playwright-with-port.js tests/e2e/accessibility.spec.ts --headed",
    "test:chaos": "node scripts/run-playwright-with-port.js tests/e2e/monkey-test.spec.ts",
    "test:stress": "node scripts/run-playwright-with-port.js tests/e2e/network-stress.spec.ts",
    "test:stress:deep": "node scripts/run-playwright-with-port.js tests/e2e/network-deep-stress.spec.ts",
    "test:fuzz": "vitest src/utils/__tests__/MathProblemGenerator.fuzz.test.ts --run",
    "test:mutation": "stryker run",
    "check:css": "node scripts/check-hardcoded-values.js",
    "check:basic-auth": "node scripts/check-basic-auth.js",
    "check:migrations": "node scripts/check-migrations.js",
    "check:db:link": "node scripts/check-db-link.js",
    "check:db:migrations": "npx supabase migration list",
    "check:db:lint": "npx supabase db lint --linked --fail-on error",
    "check:db:lint:local": "npx supabase db lint --fail-on error",
    "check:db:diff": "npx supabase db diff --linked",
    "check:db:validation": "node scripts/check-db-validation.js",
    "check:db:full": "npm run check:migrations && npm run check:db:migrations && npm run check:db:lint && npm run check:db:diff && npm run check:db:validation",
    "check:db": "npm run check:migrations && npm run check:db:migrations && npm run check:db:lint && npm run check:db:validation",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "check:nav": "node scripts/check-navigation.cjs",
    "check:circular": "madge --circular --extensions ts,tsx src/",
    "check:logic": "vitest src/utils/__tests__/logic_latency.test.ts --run",
    "check:secrets": "node scripts/check-secrets.js",
    "check:supabase:connection": "node scripts/check-supabase-connection.js",
    "check:env": "node scripts/check-env.js",
    "check:spell": "npx cspell \"src/**/*.{ts,tsx}\"",
    "check:magic": "node scripts/check-magic-strings.js",
    "check:integrity": "npm run check:css && npm run check:nav && npm run check:spell && npm run check:magic",
    "check:assets": "node scripts/find-unused-assets.js",
    "check:size": "node scripts/check-bundle-size.js",
    "check:security": "npm audit --audit-level=high",
    "check:socket": "socket ci",
    "check:security:audit": "node scripts/check-security-audit.js",
    "check:leaks": "node scripts/check-memory-leaks.js",
    "check:layout": "node scripts/check-layout-standalone.js",
    "check:layout:my-page": "node scripts/check-layout-standalone.js --only \"My Page (Authenticated)\"",
    "check:layout:all-viewports": "node scripts/check-layout-standalone.js --all-viewports",
    "check:layout:my-page:all-viewports": "node scripts/check-layout-standalone.js --only \"My Page (Authenticated)\" --all-viewports",
    "check:layout:deep": "node scripts/check-layout-standalone.js --deep",
    "check:layout:with-server": "node scripts/run-layout-check-with-server.js",
    "check:layout:deep:with-server": "node scripts/run-layout-check-with-server.js --deep",
    "check:layout:analyze": "node scripts/analyze-layout-overflow.js",
    "check:score": "node scripts/check-lighthouse-score.js",
    "prepare": "husky",
    "postinstall": "node scripts/ensure-env.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "report:lint": "npm run lint > reports/logs/lint_output.txt",
    "report:test": "npm run test:all > reports/logs/test_output.txt",
    "report:validate": "npm run validate > reports/logs/validate-log.txt",
    "report:ci": "npm run ci:local > reports/logs/ci-local-log.txt",
    "pre-report": "powershell -Command \"New-Item -ItemType Directory -Force reports/logs, reports/analysis, reports/security, reports/ci-reports\""
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/react": "^10.36.0",
    "@supabase/supabase-js": "^2.84.0",
    "@t3-oss/env-core": "^0.13.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.5",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@capacitor/cli": "^8.0.1",
    "@eslint/js": "^9.20.0",
    "@playwright/experimental-ct-react": "^1.57.0",
    "@playwright/test": "^1.57.0",
    "@sentry/vite-plugin": "^4.9.1",
    "@socketsecurity/cli": "^1.1.0",
    "@storybook/addon-a11y": "^10.2.0",
    "@storybook/addon-docs": "^10.2.0",
    "@storybook/addon-onboarding": "^10.2.0",
    "@storybook/react-vite": "^10.2.0",
    "@stryker-mutator/core": "^9.4.0",
    "@stryker-mutator/typescript-checker": "^9.4.0",
    "@stryker-mutator/vitest-runner": "^9.4.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-istanbul": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.23",
    "canvas": "^3.2.1",
    "chrome-launcher": "^1.1.0",
    "cross-env": "^10.1.0",
    "cspell": "^9.6.2",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-storybook": "^10.2.10",
    "glob": "^11.0.0",
    "globals": "^16.4.0",
    "hoist-non-react-statics": "^3.3.2",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "knip": "^5.82.1",
    "lighthouse": "^12.6.0",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "msw": "^2.12.7",
    "plop": "^4.0.5",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "react-is": "^19.2.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "sharp": "^0.34.5",
    "storybook": "^10.2.0",
    "supabase": "^2.76.12",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "fast-xml-parser": "5.3.4",
    "find-my-way": "^8.2.2",
    "ip": "npm:ipaddr.js@^2.1.0",
    "@react-native-community/cli-doctor": {
      "ip": "npm:ipaddr.js@^2.1.0"
    },
    "@react-native-community/cli-hermes": {
      "ip": "npm:ipaddr.js@^2.1.0"
    },
    "tar": "^7.5.8",
    "minimatch": "^10.0.0",
    "glob": "^11.0.0",
    "precinct": "^11.0.0",
    "tmp": "^0.2.3",
    "cross-spawn": "^7.0.5",
    "micromatch": "^4.0.8",
    "serialize-javascript": "^7.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,css}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "knip": {
    "ignore": [
      "src/stories/**"
    ],
    "ignoreBinaries": [
      "ait"
    ],
    "ignoreDependencies": [
      "@storybook/react"
    ]
  }
}
